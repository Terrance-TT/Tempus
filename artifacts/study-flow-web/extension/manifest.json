{
  "manifest_version": 3,
  "name": "Tempus Focus 4",
  "version": "4.0.0",
  "description": "Blocks distracting websites during your Tempus schedule. All settings are managed on the Tempus website.",
  "permissions": ["storage", "alarms", "declarativeNetRequest", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tempus Focus 4"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
