{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node"],
      "phase": {
        "setup": {
          "nixPkgs": ["nodejs", "pnpm"]
        },
        "build": {
          "cmds": [
            "pnpm install",
            "BASE_PATH=/ PORT=3000 VITE_API_BASE_URL=${RAILWAY_API_BASE_URL} pnpm --filter @workspace/study-flow-web run build"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npx serve artifacts/study-flow-web/dist/public -l ${PORT:-3000}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
